generator client {
  provider = "prisma-client"
  output   = "./client"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  CUSTOMER
  CLEANER
}

enum PoolType {
  INGROUND
  ABOVE_GROUND
  SPA
  COMMERCIAL
}

enum JobStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())

  customerProfile CustomerProfile?
  cleanerProfile  CleanerProfile?
  jobsPosted      Job[]    @relation("CustomerJobs")
  bidsPlaced      Bid[]    @relation("CleanerBids")
  reviewsGiven    Review[]   @relation("Reviewer")
  reviewsReceived Review[]   @relation("Reviewee")
  savedJobs       SavedJob[]

  @@map("users")
}

model CustomerProfile {
  id      String  @id @default(cuid())
  userId  String  @unique
  address String?
  lat     Float?
  lng     Float?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model CleanerProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  bio             String?
  experienceYears Int     @default(0)
  serviceRadiusKm Float   @default(25)
  lat             Float?
  lng             Float?
  avgRating       Float   @default(0)
  totalJobsDone   Int     @default(0)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cleaner_profiles")
}

model Job {
  id            String    @id @default(cuid())
  customerId    String
  cleanerId     String?
  title         String
  description   String
  poolType      PoolType
  address       String
  lat           Float
  lng           Float
  preferredDate DateTime
  status        JobStatus @default(OPEN)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  customer User   @relation("CustomerJobs", fields: [customerId], references: [id])
  bids       Bid[]
  reviews    Review[]
  savedBy    SavedJob[]

  @@index([status])
  @@map("jobs")
}

model Bid {
  id            String    @id @default(cuid())
  jobId         String
  cleanerId     String
  price         Float
  durationHours Float
  message       String
  status        BidStatus @default(PENDING)
  createdAt     DateTime  @default(now())

  job     Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cleaner User @relation("CleanerBids", fields: [cleanerId], references: [id])

  @@unique([jobId, cleanerId])
  @@map("bids")
}

model SavedJob {
  id        String   @id @default(cuid())
  cleanerId String
  jobId     String
  createdAt DateTime @default(now())

  cleaner User @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  job     Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([cleanerId, jobId])
  @@map("saved_jobs")
}

model Review {
  id         String   @id @default(cuid())
  jobId      String   @unique
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  job      Job  @relation(fields: [jobId], references: [id])
  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewee User @relation("Reviewee", fields: [revieweeId], references: [id])

  @@map("reviews")
}
